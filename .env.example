# ============================================================
# Database Configuration
# ============================================================
# Database type: "sqlite" or "postgresql"
DB_TYPE=sqlite

# --- SQLite Configuration (used when DB_TYPE=sqlite) ---
# Path to SQLite database file (relative or absolute)
SQLITE_DB_PATH=./data/app.db

# --- PostgreSQL Configuration (used when DB_TYPE=postgresql) ---
# Uncomment and fill these when using PostgreSQL
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=myapp

# ============================================================
# Redis Configuration
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================================
# API Server Configuration
# ============================================================
# 0.0.0.0 = localhost
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================
# Queue Configuration (if using Redis queues)
# ============================================================
QUEUE_NAME=default_queue

# ============================================================
# JWT Authentication
# ============================================================
JWT_SECRET_KEY=your-secret-key-change-this-in-production-use-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# python -c "import base64; import os; print(base64.b64encode(os.urandom(32)).decode())"
AES_SECRET_KEY=your-32-byte-base64-encoded-key

# ============================================================
# CORS Configuration
# ============================================================
# Comma-separated list of allowed origins
# Example: http://localhost:3000,https://yourdomain.com
# Or use * to allow all origins (not recommended for production)
BACKEND_CORS_ORIGINS=*

# ============================================================
# Additional Project-Specific Settings
# ============================================================
# Add your custom environment variables here
# Example:
# EXTERNAL_API_KEY=your_api_key
# MAX_UPLOAD_SIZE=10485760
